# Server-side code reads any variable you set in the Dockhold dashboard.
# Variables that must reach the browser need the NEXT_PUBLIC_ prefix and are
# inlined at BUILD time — set them before you deploy. Never put a secret behind
# that prefix.
#
# Keep API keys and tokens in the Vault and read them only in server code.
# PORT is provided by Dockhold at runtime — the start script reads it.
NEXT_PUBLIC_SITE_NAME=Next.js on Dockhold

# If you enable the managed database add-on, Dockhold injects DATABASE_URL.
